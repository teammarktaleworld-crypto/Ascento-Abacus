{
  "info": {
    "name": "Teacher API Collection",
    "description": "Teacher onboarding and first-login password change flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://ascento-abacus-backend.onrender.com/api" },
    { "key": "adminEmail", "value": "admin@school.com" },
    { "key": "adminPassword", "value": "admin@123" },
    { "key": "adminSessionKey", "value": "" },
    { "key": "domainId", "value": "" },
    { "key": "suffix", "value": "{{$timestamp}}" },
    { "key": "teacherId", "value": "" },
    { "key": "teacherUserId", "value": "" },
    { "key": "teacherEmail", "value": "" },
    { "key": "teacherTempPassword", "value": "" },
    { "key": "teacherNewPassword", "value": "Teacher@123" },
    { "key": "teacherSessionKey", "value": "" }
  ],
  "item": [
    {
      "name": "01 Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('adminSessionKey', json.data.sessionKey);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/auth/admin/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        }
      }
    },
    {
      "name": "02 Create Teacher By Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('teacherId', json.data.teacher._id);",
              "pm.collectionVariables.set('teacherUserId', json.data.teacher.userId);",
              "pm.collectionVariables.set('teacherEmail', json.data.teacherEmail);",
              "pm.collectionVariables.set('teacherTempPassword', json.data.temporaryPassword);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "x-session-key", "value": "{{adminSessionKey}}"},
          {"key": "Content-Type", "value": "application/json"}
        ],
        "url": "{{baseUrl}}/admin/teachers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aarav Sharma\",\n  \"email\": \"aarav.sharma.{{suffix}}@school.com\",\n  \"phone\": \"98{{suffix}}\",\n  \"domainId\": \"{{domainId}}\",\n  \"status\": \"active\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"country\": \"India\",\n  \"dateOfBirth\": \"1985-06-15\",\n  \"gender\": \"male\",\n  \"qualification\": \"M.Sc. Mathematics\",\n  \"experienceYears\": 10,\n  \"joiningDate\": \"2020-04-01\",\n  \"profilePhoto\": \"https://res.cloudinary.com/demo/image/upload/sample.jpg\"\n}"
        }
      }
    },
    {
      "name": "03 Teacher Login With Temporary Password (userId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('teacherSessionKey', json.data.sessionKey);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{teacherUserId}}\",\n  \"password\": \"{{teacherTempPassword}}\",\n  \"role\": \"teacher\"\n}"
        }
      }
    },
    {
      "name": "04 Change Password (first login)",
      "request": {
        "method": "POST",
        "header": [{"key": "x-session-key", "value": "{{teacherSessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/teachers/change-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{teacherTempPassword}}\",\n  \"newPassword\": \"{{teacherNewPassword}}\"\n}"
        }
      }
    },
    {
      "name": "05 Teacher Login With Permanent Password (email)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"{{teacherEmail}}\",\n  \"password\": \"{{teacherNewPassword}}\",\n  \"role\": \"teacher\"\n}"
        }
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/dashboard",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","dashboard"]
        }
      }
    },
    {
      "name": "Mark Attendance",
      "request": {
        "method": "POST",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/attendance",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","attendance"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"class\": \"5A\",\n  \"date\": \"2026-03-17\",\n  \"students\": [\n    {\"name\": \"John Doe\", \"status\": \"present\"},\n    {\"name\": \"Jane Doe\", \"status\": \"absent\"}\n  ]\n}"
        }
      }
    },
    {
      "name": "Get Attendance",
      "request": {
        "method": "GET",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/attendance?class=5A&date=2026-03-17",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","attendance"],
          "query": [
            {"key": "class", "value": "5A"},
            {"key": "date", "value": "2026-03-17"}
          ]
        }
      }
    },
    {
      "name": "Create Assignment",
      "request": {
        "method": "POST",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/homework",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","homework"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Math Homework\",\n  \"description\": \"Solve algebra problems\",\n  \"dueDate\": \"2026-03-20\",\n  \"class\": \"5A\"\n}"
        }
      }
    },
    {
      "name": "Update Assignment",
      "request": {
        "method": "PUT",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/homework/assignmentId",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","homework","assignmentId"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Homework\",\n  \"description\": \"New description\"\n}"
        }
      }
    },
    {
      "name": "Delete Assignment",
      "request": {
        "method": "DELETE",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/homework/assignmentId",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","homework","assignmentId"]
        }
      }
    },
    {
      "name": "Get Assignments",
      "request": {
        "method": "GET",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/homework?class=5A",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","homework"],
          "query": [
            {"key": "class", "value": "5A"}
          ]
        }
      }
    },
    {
      "name": "Create Content",
      "request": {
        "method": "POST",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/content",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","content"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Math Notes\",\n  \"description\": \"Algebra basics\",\n  \"type\": \"note\",\n  \"classId\": \"classObjectId\",\n  \"studentId\": \"studentObjectId\",\n  \"visibleTo\": [\"studentObjectId\"]\n}"
        }
      }
    },
    {
      "name": "Update Content",
      "request": {
        "method": "PUT",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}, {"key": "Content-Type", "value": "application/json"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/content/contentId",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","content","contentId"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Notes\",\n  \"description\": \"Updated description\"\n}"
        }
      }
    },
    {
      "name": "Delete Content",
      "request": {
        "method": "DELETE",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/content/contentId",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","content","contentId"]
        }
      }
    },
    {
      "name": "Get All Content",
      "request": {
        "method": "GET",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/content",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","content"]
        }
      }
    },
    {
      "name": "Get Content for Student",
      "request": {
        "method": "GET",
        "header": [{"key": "x-session-key", "value": "{{sessionKey}}"}],
        "url": {
          "raw": "https://ascento-abacus.onrender.com/api/teacher/content/studentObjectId",
          "protocol": "https",
          "host": ["ascento-abacus","onrender","com"],
          "path": ["api","teacher","content","studentObjectId"]
        }
      }
    }
  ]
}
