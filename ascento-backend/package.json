{
    "name": "school-erp-backend",
    "version": "2.0.0",
    "description": "Production-ready School ERP backend API",
    "main": "server.js",
    "type": "commonjs",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node src/scripts/seed.js",
        "seed:demo": "node src/scripts/seed.js --teachers=4 --students=12 --applications=10",
        "apis:routes": "node src/scripts/generate-all-apis.js"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "cloudinary": "^2.8.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.0",
        "express": "^4.22.1",
        "express-rate-limit": "^6.7.0",
        "helmet": "^6.0.1",
        "joi": "^17.13.3",
        "jsonwebtoken": "^9.0.0",
        "mongoose": "^7.0.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.2",
        "node-cron": "^4.2.1",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "nodemon": "^2.0.22"
